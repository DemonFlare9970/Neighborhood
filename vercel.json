{
    "version": 2,
    "builds": [
        {
            "src": "package.json",
            "use": "@vercel/static-build"
        }
    ],
    "routes": [
        { "src": "/(manifest.json|favicon.ico|logo.svg|asset-manifest.json|robots.txt)", "dest": "/$1" },
        { "src": "/static/(.*)", "dest": "/static/$1" },
        { "src": "/(.*)", "dest": "/index.html" }
    ]
}